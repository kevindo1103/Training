# Local development defaults
DATABASE_URL=sqlite:///./training.db
PORT=8000
ENV=dev
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Auth secrets - MUST be overridden in production / staging
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
FACILITATOR_SECRET=set-a-strong-secret-here

# Production / Staging overrides (set by CI/CD secrets or systemd env)
# DATABASE_URL=sqlite:///opt/dolphin-training/data/training.db
# CORS_ORIGINS=https://dolphin-training.vercel.app
# DEFAULT_SESSION_ID=default-module1-session
# DEFAULT_MODULE_ID=module1
